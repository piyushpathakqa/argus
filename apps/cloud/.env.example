# Vigilis Governance Cloud — environment (TRE-63)
# Copy to .env.local for local dev. NEVER commit a real .env / secrets.

# --- Auth.js (required) ---------------------------------------------------
# Session/JWT signing secret. Generate one with:
#   openssl rand -base64 32
AUTH_SECRET=

# --- GitHub OAuth (optional for local dev) --------------------------------
# Create a free GitHub OAuth app (see README "GitHub OAuth app"):
#   Settings > Developer settings > OAuth Apps > New OAuth App
#   Homepage URL:            http://localhost:3300
#   Authorization callback:  http://localhost:3300/api/auth/callback/github
# Then paste the Client ID / generated Client secret here.
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# --- Local dev bypass -----------------------------------------------------
# Set to 1 to enable the no-password "Dev login" (signs in dev@vigilis.local)
# so the app works with zero GitHub setup. Dev login is ALSO auto-enabled when
# no GitHub creds are set, and is HARD-DISABLED whenever real GitHub creds are
# present — so it can never be used in a configured production deployment.
VIGILIS_CLOUD_DEV=1

# --- Storage (optional) ---------------------------------------------------
# Override the SQLite DB path (defaults to apps/cloud/.data/cloud.db).
# VIGILIS_CLOUD_DB=/absolute/path/to/cloud.db
