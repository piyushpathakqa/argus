# Argus configuration — copy to .env and fill in.

# Required: Anthropic API key for the agent core.
ANTHROPIC_API_KEY=sk-ant-...

# Model overrides (optional). Defaults are set in @argus/core.
# Deep-reasoning model used for generate + triage.
ARGUS_MODEL_PRIMARY=claude-opus-4-8
# Cheaper model used for lightweight steps.
ARGUS_MODEL_FAST=claude-haiku-4-5

# Optional: GitHub token used by the heal behavior to open PRs in CI.
# In GitHub Actions this is provided automatically as GITHUB_TOKEN.
# GITHUB_TOKEN=ghp_...
